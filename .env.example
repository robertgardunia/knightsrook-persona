ANTHROPIC_API_KEY=
PERSONA_ID=default
MODEL=claude-sonnet-4-6
# Hot-buffer budget as a fraction of the model window. Generous on purpose:
# in-context recall is faster and lossless vs. vector retrieval. Capture runs
# every response, so the buffer can stay large and trim by dumb FIFO.
CONTEXT_BUDGET_PCT=0.65

# MySQL — structured storage (turns, factual retrieval)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=knightsrook_persona
DB_USER=
DB_PASS=

# Postgres+pgvector — cohesion/semantic retrieval
PG_HOST=127.0.0.1
PG_PORT=5433
PG_DB=persona
PG_USER=persona
PG_PASS=persona

# Ollama — local embeddings (nomic-embed-text, 768 dims)
OLLAMA_HOST=http://localhost:11434
