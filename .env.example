ANTHROPIC_API_KEY=
PERSONA_ID=default
MODEL=claude-sonnet-4-6
# Hot-buffer budget as a fraction of the model window. Generous on purpose:
# in-context recall is faster and lossless vs. vector retrieval. Capture runs
# every response, so the buffer can stay large and trim by dumb FIFO.
CONTEXT_BUDGET_PCT=0.65

# MySQL — structured storage (turns, factual retrieval)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=knightsrook_persona
DB_USER=
DB_PASS=

# Postgres+pgvector — cohesion/semantic retrieval
PG_HOST=127.0.0.1
PG_PORT=5433
PG_DB=persona
PG_USER=persona
PG_PASS=persona

# Ollama — local model runtime
OLLAMA_HOST=http://localhost:11434
# Embeddings — the "ruler": purpose-built measurement, nomic-embed-text (768 dims)
# Cognition — the local "support brain": introspection + chaos-goblin finding.
# Sits below the persona's tier; replaces the old llama3.2:3b. Reasoning, not the entity.
OLLAMA_COGNITION_MODEL=gemma3:12b
# Seconds/duration Ollama keeps the 12B in VRAM after a cognitive call. '0' =
# unload immediately (gaming-friendly default — the GPU is freed the instant the
# job finishes). Raise (e.g. '5m') only when a batch consumer runs many calls.
OLLAMA_COGNITION_KEEPALIVE=0
